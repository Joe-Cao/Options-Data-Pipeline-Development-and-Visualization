                          <formatted-text>
                            <run fontcolor='#000000' fontname='Noto Sans SC Black' fontsize='28'>Introduction</run>
                            <run>Æ&#10;&#10;&#10;&#10;</run>
                            <run fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'>This time, we present three groups of information from the options data:</run>
                            <run>Æ&#10;&#10;&#10;</run>
                            <run fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'>1. </run>
                            <run bold='true' fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'>Implied volatility curves</run>
                            <run fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'> for different </run>
                            <run bold='true' fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'>quote dates</run>
                            <run fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'> and </run>
                            <run bold='true' fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'>expiries</run>
                            <run fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'>, including both the </run>
                            <run bold='true' fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'>volatility smile</run>
                            <run fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'> and the </run>
                            <run bold='true' fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'>volatility skew</run>
                            <run fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'>.</run>
                            <run>Æ&#10;&#10;&#10;</run>
                            <run fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'>2. For options across different </run>
                            <run bold='true' fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'>quote dates</run>
                            <run fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'>, the relationship between </run>
                            <run bold='true' fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'>relative spread and open interest</run>
                            <run fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'>, as well as the relationship between </run>
                            <run bold='true' fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'>relative spread and volume</run>
                            <run fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'>.</run>
                            <run>Æ&#10;&#10;&#10;</run>
                            <run fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'>3.For each </run>
                            <run bold='true' fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'>expiry</run>
                            <run fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'>, the evolution of the option </run>
                            <run bold='true' fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'>25-delta skew</run>
                            <run fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'> over </run>
                            <run bold='true' fontcolor='#000000' fontname='Noto Sans TC' fontsize='20'>quote dates</run>
